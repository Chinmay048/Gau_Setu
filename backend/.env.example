# Backend Environment Variables for SQLite Deployment
# Copy values for production deployment

# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Configuration (REQUIRED for deployment)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_random_string_minimum_32_characters

# JWT Expiration
JWT_EXPIRE=7d

# Frontend URL (REQUIRED - Set to your deployed frontend domain for CORS)
# Example: https://username.github.io/Gau_Setu/
FRONTEND_URL=http://localhost:5173

# Database - SQLite (automatic, no configuration needed)
# Database file will be created at: ./database/livestock.db

# File Upload (Optional)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Breed Detection Model (Optional)
BREED_MODEL_ENDPOINT=http://localhost:5001/predict
BREED_MODEL_API_KEY=your_model_api_key

# Email Service (Optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# AWS S3 (Optional)
AWS_S3_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1
